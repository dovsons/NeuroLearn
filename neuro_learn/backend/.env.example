# NeuroLearn Backend Configuration

# Server Port
PORT=3000

# Google Cloud Speech-to-Text Configuration (if using Google Cloud)
GOOGLE_APPLICATION_CREDENTIALS=./path/to/your/google-credentials.json

# Alternative: If using a different speech-to-text service
# Add your service credentials here
SPEECH_API_KEY=your_api_key_here
SPEECH_API_URL=https://api.example.com/v1/speech

# Logging
LOG_LEVEL=info
